    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "ajv": "^8.17.1",
    "axios": "^1.6.5",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.4.1",
    "classnames": "^2.5.1",
    "env-cmd": "^10.1.0",
    "jquery": "^3.7.1",
    "js-cookie": "^3.0.5",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mqtt": "^5.15.0",
    "nouislider": "^15.8.1",
