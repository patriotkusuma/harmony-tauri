    "react-router-dom": "^7.13.1",
    "react-secure-storage": "^1.3.2",
    "react-thermal-printer": "^0.22.0",
    "react-toastify": "^11.0.5",
    "reactstrap": "^9.2.3",
    "sass": "^1.98.0",
    "serialport": "^13.0.0",
    "socket.io-client": "^4.7.5",
    "sweetalert2": "^11.26.21",
    "zustand": "^5.0.11"
