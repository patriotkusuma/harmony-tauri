{
  "name": "harmony-laundry",
  "version": "1.2.4",
  "description": "Harmony Laundry Point of Sale",
  "main": "electron/main.js",
  "homepage": ".",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creativetimofficial/argon-dashboard-react.git"
  },
  "keywords": [
    "react",
    "electron",
    "pos",
    "laundry"
  ],
  "author": "Harmony Laundry",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/creativetimofficial/argon-dashboard-react/issues"
  },
    "scripts": {
    "start": "env-cmd -f .env react-scripts start",
    "start:tauri": "sh -c 'if [ -f .env ]; then BROWSER=none PORT=3010 env-cmd -f .env react-scripts start; else BROWSER=none PORT=3010 react-scripts start; fi'",
    "build": "react-scripts build",
    "build:server": "PUBLIC_URL=/ react-scripts build",
    "build:electron": "PUBLIC_URL=. react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "compile:scss": "sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.css",
    "minify:scss": "sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.min.css --style compressed",
    "build:scss": "sass --load-path=node_modules src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.css",
    "electron:dev": "electron .",
    "electron:dev:server": "ELECTRON_USE_DEV_SERVER=1 electron .",
    "electron:serve": "concurrently -k \"BROWSER=none npm start\" \"wait-on http://localhost:3010 && npm run electron:dev:server\"",
    "electron:dist": "npm run build:electron && electron-builder",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "kasir:check:server": "bash scripts/kasir-server-check.sh",
    "kasir:deploy": "bash scripts/kasir-deploy.sh"
  },
  "build": {
    "extends": null,
    "appId": "com.harmony.kasir",
    "productName": "HarmonyLaundry",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "linux": {
      "executableName": "harmony-laundry",
      "target": [
        "deb"
      ],
      "category": "Utility",
      "maintainer": "harmony@example.com",
      "synopsis": "Aplikasi kasir Harmony Laundry",
      "description": "HarmonyLaundry adalah aplikasi desktop berbasis Electron untuk kebutuhan kasir harmony laundry.",
      "icon": "electron/assets/icons",
      "desktop": {
        "entry": {
          "StartupWMClass": "harmony-laundry"
        }
      }
    }
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-free": "6.5.1",
    "@serialport/parser-readline": "^13.0.0",
    "@tanstack/react-query": "^5.90.19",
    "@tauri-apps/api": "^2.10.1",
    "@tiptap/extension-bubble-menu": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "ajv": "^8.17.1",
    "axios": "^1.6.5",
    "bootstrap": "4.6.2",
    "chart.js": "2.9.4",
    "classnames": "2.3.2",
    "cra-template": "^1.2.0",
    "env-cmd": "^10.1.0",
    "jquery": "^3.7.1",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "moment": "2.29.4",
    "mqtt": "^5.15.0",
    "nouislider": "15.4.0",
    "popper.js": "^1.16.1",
    "react": "18.2.0",
    "react-chartjs-2": "2.11.2",
    "react-copy-to-clipboard": "5.1.0",
    "react-datetime": "3.2.0",
    "react-dom": "18.2.0",
    "react-medium-image-zoom": "^5.2.12",
    "react-query": "^3.39.3",
    "react-router-dom": "6.21.1",
    "react-scripts": "^5.0.1",
    "react-secure-storage": "^1.3.2",
    "react-thermal-printer": "^0.18.1",
    "react-toastify": "^10.0.5",
    "reactstrap": "8.10.0",
    "sass": "1.69.5",
    "serialport": "^13.0.0",
    "socket.io-client": "^4.7.5",
    "sweetalert2": "^11.26.21",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "concurrently": "^9.1.2",
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12",
    "gulp": "^4.0.2",
    "gulp-append-prepend": "1.0.9",
    "wait-on": "^8.0.2"
  },
  "optionalDependencies": {
    "eslint-plugin-flowtype": "8.0.3",
    "typescript": "5.3.3"
  },
  "overrides": {
    "svgo": "3.0.2",
    "fsevents": "2.3.2",
    "chokidar": "3.5.3"
  }
}
