{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HarmonyLaundry",
  "version": "1.3.2",
  "identifier": "com.harmony.kasir",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3010",
    "beforeDevCommand": "npm run start:tauri",
    "beforeBuildCommand": "npm run build:server"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HarmonyLaundry",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
