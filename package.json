{
  "name": "harmony-laundry",
  "version": "1.2.7",
  "description": "Harmony Laundry Point of Sale",
  "homepage": ".",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creativetimofficial/argon-dashboard-react.git"
  },
  "keywords": [
    "react",
    "tauri",
    "pos",
    "laundry"
  ],
  "author": "Harmony Laundry",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/creativetimofficial/argon-dashboard-react/issues"
  },
  "scripts": {
    "start": "vite",
    "start:tauri": "vite --port 3010",
    "build": "vite build",
    "build:server": "vite build",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "compile:scss": "sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.css",
    "minify:scss": "sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.min.css --style compressed",
    "build:scss": "sass --load-path=node_modules src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.css",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "kasir:check:server": "bash scripts/kasir-server-check.sh",
    "kasir:deploy": "bash scripts/kasir-deploy.sh",
    "kasir:deploy:win": "node scripts/kasir-deploy-win.js"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-free": "6.5.1",
